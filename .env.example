# Ejemplo de configuración — copiar este archivo como .env y rellenar con valores reales

# ── API ────────────────────────────────────────────────────────────────────────
# URL base del servidor (sin barra final)
API_BASE_URL=https://tu-api.app

# API Key registrada en la BD (tabla api_keys, campo key_hash = SHA-256 de esta clave)
API_KEY=tu_clave_aqui

# ── Sesgo de búsqueda por ubicación ───────────────────────────────────────────
# Coordenadas del centro de operaciones. Se usan como fallback cuando el GPS
# no está disponible o el usuario deniega el permiso de ubicación.
DEFAULT_LAT=41.3851
DEFAULT_LNG=2.1734

# Radio de búsqueda preferente en kilómetros alrededor de las coordenadas anteriores.
# Los resultados fuera de este radio se muestran igualmente si no hay alternativas.
DEFAULT_RADIUS_KM=50